; =====================================================
; MODELO de credenciais do firmware
; =====================================================
; Copie este arquivo para "secrets.ini" e preencha com os
; valores reais. O "secrets.ini" NÃO é versionado (.gitignore).

[secrets]
wifi_ssid       = NOME_DA_REDE_WIFI
wifi_pass       = SENHA_DA_REDE_WIFI
server_url_dev  = http://192.168.0.11:3000
server_url_prod = https://custo-certo.onrender.com
