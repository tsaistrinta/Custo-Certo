# =====================================================
# Custo Certo - Variáveis de Ambiente (MODELO)
# =====================================================
# Copie este arquivo para ".env" e preencha os valores.
# O ".env" real NUNCA deve ser comitado (está no .gitignore).

NODE_ENV=development
PORT=3000

# Roda o seed automático se o banco estiver vazio
AUTO_SEED=true

# --- Banco de dados ---
# Local (SQLite em arquivo):
#   DB_URL=file:./data/local.db
#   (deixe DB_AUTH_TOKEN vazio)
#
# Turso (cloud):
#   DB_URL=libsql://SEU-BANCO.turso.io
#   DB_AUTH_TOKEN=(token gerado pelo Turso CLI)
DB_URL=file:./data/local.db
DB_AUTH_TOKEN=

# Opcional: domínios autorizados em produção (separados por vírgula)
# Ex.: ALLOWED_ORIGINS=https://custo-certo.onrender.com
ALLOWED_ORIGINS=
